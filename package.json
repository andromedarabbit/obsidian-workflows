{
  "name": "obsidian-workflows",
  "version": "0.1.3",
  "private": true,
  "description": "Plugin core for Obsidian writing workflows",
  "scripts": {
    "validate:commands": "node scripts/validate-commands.js",
    "validate:no-duplicates": "node scripts/check-duplicates.js",
    "lint:markdown": "markdownlint-cli2 '**/*.md' '#node_modules'",
    "lint:frontmatter": "node scripts/lint-frontmatter.js",
    "generate:command-index": "bash tools/generate-index.sh",
    "validate:fast": "bash tools/validate-fast.sh",
    "validate:generated": "bash tools/validate-generated.sh",
    "validate:workflows": "bash tools/validate-workflows.sh",
    "validate:behavior-contracts": "node scripts/validate-behavior-contracts.js",
    "test:plan-passive-default": "node scripts/test-plan-passive-default.js",
    "validate:ci": "bash tools/validate-ci.sh",
    "validate:all": "npm run validate:ci"
  },
  "devDependencies": {
    "markdownlint-cli2": "^0.12.0",
    "js-yaml": "^4.1.0",
    "gray-matter": "^4.0.3"
  }
}
